<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VRChat OSC Tracker"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Stopped"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Permissions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_perm_usage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✗ Usage access required"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_grant_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant usage access"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_perm_media"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✗ Notification listener (optional)"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_grant_media"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant notification access"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="24dp"/>

        <!-- OSC Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OSC Target"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Host IP (use 127.0.0.1 for same device, or PC LAN IP)"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="127.0.0.1"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OSC Port (VRChat default: 9000)"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="9000"
            android:inputType="number"
            android:layout_marginBottom="24dp"/>

        <!-- Tracker Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tracker Settings"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update interval (seconds)"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/et_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="5"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <Switch
            android:id="@+id/sw_show_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show current time"
            android:checked="true"
            android:layout_marginBottom="8dp"/>

        <Switch
            android:id="@+id/sw_show_media"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show now playing media"
            android:checked="true"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save settings"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_start_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start tracker"
            android:layout_marginBottom="20dp"/>

        <!-- Info box -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message format:\n📱 App Name  |  🎵 Artist - Title  [HH:mm]\n\nEnsure OSC is enabled in VRChat:\nSettings → OSC → Enable"
            android:textSize="12sp"
            android:padding="12dp"
            android:background="@drawable/bg_info_box"
            android:lineSpacingMultiplier="1.4"/>

    </LinearLayout>
</ScrollView>
